# CamDetect Server Environment Variables

# Database connection (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/camdetect

# JWT secret for token signing (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server port
PORT=3000

# Rate limiting (optional)
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=60

# App attestation (optional, for future use)
APP_ATTEST_REQUIRED=false
