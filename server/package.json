{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "db:migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "bun": "^1.1.0",
    "postgres": "^3.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.3.3"
  }
}
